{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            // If you have changed target frameworks, make sure to update the program path.
            "program": "${workspaceFolder}/src/web/EsperancaSolidaria.API/bin/Debug/net10.0/EsperancaSolidaria.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/web/EsperancaSolidaria.API",
            "stopAtEntry": false,
            // Enable launching the browser with a specific URL after starting the application.
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            // Configure environment variables, if needed.
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/web/EsperancaSolidaria.API/Views"
            }
        }
    ]
}